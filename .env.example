# Copy to .env.local and fill in values.
# Full dedicated mainnet RPC URL (Alchemy/Infura/PublicNode/etc).
VITE_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
# WalletConnect project ID from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── Push Chat community rooms ───────────────────────────────────────────────
# Base URL of the deployed token-gate function (defaults to the prod domain):
# VITE_GATE_URL=https://gov.bittrees.org/api/gate
#
# Room chatIds live in the registry (/api/rooms, Vercel KV) and are published
# automatically when an admin creates a room (Admin console → Community rooms) —
# no redeploy. Connect a Vercel KV / Upstash store to the project; it injects
# KV_REST_API_URL + KV_REST_API_TOKEN automatically (server-side, not VITE_*).
#
# The VITE_PUSH_ROOM_* vars below are an OPTIONAL fallback if you don't use KV
# (paste a created chatId here, then redeploy):
#
# BGOV-tier rooms:
# VITE_PUSH_ROOM_SHAREHOLDERS=
# VITE_PUSH_ROOM_ASSOCIATES=
# VITE_PUSH_ROOM_JUNIOR=
# VITE_PUSH_ROOM_PARTNERS=
#
# ENS-subname rooms (gated to each Safe's signers & proposers):
# VITE_PUSH_ROOM_SAFE_GOV=
# VITE_PUSH_ROOM_SAFE_CAPITAL=
# VITE_PUSH_ROOM_SAFE_RESEARCH=
# VITE_PUSH_ROOM_SAFE_BUSINESS=
# VITE_PUSH_ROOM_SAFE_TECHNOLOGY=
# VITE_PUSH_ROOM_SAFE_COMMUNITY=
